@model AIJobHelper.Application.DTOs.Resume.ResumeAnalysisDto

<div class="card stat-card mb-3">
    <div class="card-header bg-transparent fw-semibold py-3">
        <i class="bi bi-stars me-1 text-primary"></i>AI Analysis
        <span class="text-muted small fw-normal ms-2">@Model.CreatedAt.ToString("MMM d, yyyy h:mm tt")</span>
    </div>
    <div class="card-body">
        <!-- Summary -->
        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Summary</h6>
        <p class="mb-4">@Model.Summary</p>

        <!-- Strengths -->
        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Strengths</h6>
        <ul class="mb-4">
            @foreach (var s in Model.Strengths)
            {
                <li class="mb-1">@s</li>
            }
        </ul>

        <!-- Weaknesses -->
        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Areas to Improve</h6>
        <ul class="mb-4">
            @foreach (var w in Model.Weaknesses)
            {
                <li class="mb-1">@w</li>
            }
        </ul>

        <!-- Suggested job titles -->
        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Suggested Job Titles</h6>
        <div>
            @foreach (var t in Model.Suggestions)
            {
                <span class="skill-pill bg-primary bg-opacity-10 text-primary">@t</span>
            }
        </div>
    </div>
</div>
