@page
@model AIJobHelper.API.Pages.Resumes.ResumesIndexModel
@{
    ViewData["Title"] = "Resumes";
    ViewData["ActivePage"] = "Resumes";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Resumes</h1>
        <p class="text-muted mb-0">Upload and manage your resumes</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
        <i class="bi bi-upload me-1"></i> Upload Resume
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Resumes.Any())
{
    <div class="card stat-card p-5 text-center">
        <div class="fs-1 text-muted mb-3"><i class="bi bi-file-earmark-person"></i></div>
        <h5>No resumes yet</h5>
        <p class="text-muted">Upload your first resume to get started with AI analysis.</p>
        <div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                <i class="bi bi-upload me-1"></i> Upload Resume
            </button>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var r in Model.Resumes)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="fs-2 text-primary"><i class="bi bi-file-earmark-@(r.FileType == "pdf" ? "pdf" : "word")"></i></div>
                            <div class="overflow-hidden">
                                <div class="fw-semibold text-truncate" title="@r.FileName">@r.FileName</div>
                                <div class="text-muted small">@r.FileType.ToUpper() · @r.UploadedAt.ToString("MMM d, yyyy")</div>
                            </div>
                        </div>
                        <div class="mt-auto d-flex gap-2">
                            <a href="/Resumes/Detail?id=@r.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="bi bi-eye me-1"></i>View & Analyse
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    onclick="deleteResume('@r.Id', '@r.FileName.Replace("'", "\\'")')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">Upload Resume</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Resume file</label>
                        <input type="file" name="file" class="form-control" accept=".pdf,.docx" required />
                        <div class="form-text">PDF or DOCX, max 10 MB.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete resume?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">This will permanently delete <strong id="deleteFileName"></strong> and its analysis.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="Delete" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function deleteResume(id, name) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteFileName').textContent = name;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
}
