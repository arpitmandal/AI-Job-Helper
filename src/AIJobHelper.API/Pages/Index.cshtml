@page
@model AIJobHelper.API.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Dashboard</h1>
        <p class="text-muted mb-0">AI-powered job application assistant</p>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="card stat-card p-4">
            <div class="stat-value">@Model.ResumeCount</div>
            <div class="text-muted">Resumes uploaded</div>
            <a href="/Resumes" class="btn btn-sm btn-outline-primary mt-3">
                <i class="bi bi-arrow-right me-1"></i>View Resumes
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card p-4">
            <div class="stat-value text-secondary">—</div>
            <div class="text-muted">ATS scores (Phase 2)</div>
            <span class="badge bg-light text-secondary mt-3">Coming soon</span>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card p-4">
            <div class="stat-value text-secondary">—</div>
            <div class="text-muted">Cover letters (Phase 3)</div>
            <span class="badge bg-light text-secondary mt-3">Coming soon</span>
        </div>
    </div>
</div>

<h5 class="fw-semibold mb-3">Get started</h5>
<div class="row g-3">
    <div class="col-md-4">
        <a href="/Resumes" class="card stat-card p-4 text-decoration-none text-dark d-block h-100">
            <div class="fs-2 mb-2 text-primary"><i class="bi bi-upload"></i></div>
            <div class="fw-semibold">Upload Resume</div>
            <div class="text-muted small mt-1">Upload a PDF or DOCX resume and get an AI-powered analysis.</div>
        </a>
    </div>
    <div class="col-md-4">
        <div class="card stat-card p-4 h-100 opacity-50">
            <div class="fs-2 mb-2 text-secondary"><i class="bi bi-bar-chart-line"></i></div>
            <div class="fw-semibold">ATS Scorer</div>
            <div class="text-muted small mt-1">Match your resume to a job description. Available in Phase 2.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card p-4 h-100 opacity-50">
            <div class="fs-2 mb-2 text-secondary"><i class="bi bi-envelope-paper"></i></div>
            <div class="fw-semibold">Cover Letter</div>
            <div class="text-muted small mt-1">Generate a tailored cover letter. Available in Phase 3.</div>
        </div>
    </div>
</div>
