@page
@model AIJobHelper.API.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Dashboard</h1>
        <p class="text-muted mb-0">AI-powered job application assistant</p>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="card stat-card p-4">
            <div class="stat-value">@Model.ResumeCount</div>
            <div class="text-muted">Resumes uploaded</div>
            <a href="/Resumes" class="btn btn-sm btn-outline-primary mt-3">
                <i class="bi bi-arrow-right me-1"></i>View Resumes
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card p-4">
            <div class="stat-value">@Model.AtsCount</div>
            <div class="text-muted">ATS scores run</div>
            <a href="/Ats" class="btn btn-sm btn-outline-primary mt-3">
                <i class="bi bi-arrow-right me-1"></i>ATS Scorer
            </a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card p-4">
            <div class="stat-value">@Model.CoverLetterCount</div>
            <div class="text-muted">Cover letters generated</div>
            <a href="/CoverLetters/Generate" class="btn btn-sm btn-outline-primary mt-3">
                <i class="bi bi-arrow-right me-1"></i>Generate Letter
            </a>
        </div>
    </div>
</div>

<h5 class="fw-semibold mb-3">Get started</h5>
<div class="row g-3">
    <div class="col-md-4">
        <a href="/Resumes" class="card stat-card p-4 text-decoration-none text-dark d-block h-100">
            <div class="fs-2 mb-2 text-primary"><i class="bi bi-upload"></i></div>
            <div class="fw-semibold">Upload Resume</div>
            <div class="text-muted small mt-1">Upload a PDF or DOCX resume and get an AI-powered analysis.</div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Ats" class="card stat-card p-4 text-decoration-none text-dark d-block h-100">
            <div class="fs-2 mb-2 text-primary"><i class="bi bi-bar-chart-line"></i></div>
            <div class="fw-semibold">ATS Scorer</div>
            <div class="text-muted small mt-1">Match your resume to a job description and get a detailed ATS report.</div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/CoverLetters/Generate" class="card stat-card p-4 text-decoration-none text-dark d-block h-100">
            <div class="fs-2 mb-2 text-primary"><i class="bi bi-envelope-paper"></i></div>
            <div class="fw-semibold">Cover Letter</div>
            <div class="text-muted small mt-1">Generate a tailored AI cover letter and download it as a PDF.</div>
        </a>
    </div>
</div>
