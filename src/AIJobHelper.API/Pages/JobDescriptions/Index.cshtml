@page
@model AIJobHelper.API.Pages.JobDescriptions.IndexModel
@{
    ViewData["Title"] = "Job Descriptions";
    ViewData["ActivePage"] = "JobDescriptions";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Job Descriptions</h1>
        <p class="text-muted mb-0">Click a row to preview the description. Delete ones you no longer need.</p>
    </div>
</div>

@if (!Model.JobDescriptions.Any())
{
    <div class="card stat-card p-5 text-center">
        <div class="fs-1 text-muted mb-3"><i class="bi bi-briefcase"></i></div>
        <h5>No job descriptions saved yet</h5>
        <p class="text-muted">Go to <a href="/Ats">ATS Scorer</a> or <a href="/CoverLetters/Generate">Cover Letter</a> to save a job description.</p>
    </div>
}
else
{
    <div class="card stat-card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Title / Source</th>
                        <th>Type</th>
                        <th>Saved</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var jd in Model.JobDescriptions)
                    {
                        var label = !string.IsNullOrEmpty(jd.Title)
                            ? jd.Title
                            : jd.ParsedContent.Length > 80 ? jd.ParsedContent[..80] + "…" : jd.ParsedContent;
                        <tr id="row-@jd.Id"
                            class="jd-row"
                            style="cursor:pointer"
                            data-id="@jd.Id"
                            data-label="@label"
                            data-type="@jd.SourceType"
                            data-date="@jd.CreatedAt.ToString("MMM d, yyyy h:mm tt")"
                            data-content="@jd.ParsedContent"
                            onclick="openPreview(this, event)">
                            <td class="ps-4 align-middle" style="max-width:420px">
                                <span class="text-truncate d-block" style="max-width:400px" title="@label">@label</span>
                            </td>
                            <td class="align-middle">
                                <span class="badge @(jd.SourceType == "url" ? "bg-info-subtle text-info" : "bg-secondary-subtle text-secondary")">
                                    <i class="bi @(jd.SourceType == "url" ? "bi-link-45deg" : "bi-textarea-t") me-1"></i>@jd.SourceType.ToUpper()
                                </span>
                            </td>
                            <td class="align-middle text-muted small">@jd.CreatedAt.ToString("MMM d, yyyy h:mm tt")</td>
                            <td class="text-end pe-4 align-middle" onclick="event.stopPropagation()">
                                <button class="btn btn-sm btn-outline-danger"
                                        onclick="deleteJd('@jd.Id', this)">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ── Detail Modal ───────────────────────────────────────── -->
<div class="modal fade" id="jdModal" tabindex="-1" aria-labelledby="jdModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-semibold" id="jdModalLabel"></h5>
                    <div class="d-flex gap-2 mt-1 align-items-center">
                        <span id="modalBadge" class="badge"></span>
                        <small id="modalDate" class="text-muted"></small>
                    </div>
                </div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="modalContent" style="white-space:pre-wrap;font-family:inherit;font-size:0.92rem;line-height:1.7;margin:0"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-danger" id="modalDeleteBtn" onclick="deleteFromModal()">
                    <i class="bi bi-trash me-1"></i>Delete this Job Description
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Error toast ────────────────────────────────────────── -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div class="toast align-items-center text-bg-danger border-0 d-none" id="deleteToastEl" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="deleteToastMsg"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    onclick="this.closest('.toast').classList.add('d-none')"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let activeJdId = null;
    const modal = new bootstrap.Modal(document.getElementById('jdModal'));

    function openPreview(row, event) {
        activeJdId = row.getAttribute('data-id');
        const type = row.getAttribute('data-type');

        document.getElementById('jdModalLabel').textContent = row.getAttribute('data-label');
        document.getElementById('modalDate').textContent = row.getAttribute('data-date');
        document.getElementById('modalContent').textContent = row.getAttribute('data-content');

        const badge = document.getElementById('modalBadge');
        if (type === 'url') {
            badge.className = 'badge bg-info-subtle text-info';
            badge.innerHTML = '<i class="bi bi-link-45deg me-1"></i>URL';
        } else {
            badge.className = 'badge bg-secondary-subtle text-secondary';
            badge.innerHTML = '<i class="bi bi-textarea-t me-1"></i>TEXT';
        }

        modal.show();
    }

    function deleteFromModal() {
        if (!activeJdId) return;
        modal.hide();
        // find the delete button in the table row and delegate to existing handler
        const btn = document.querySelector(`#row-${activeJdId} .btn-outline-danger`);
        if (btn) deleteJd(activeJdId, btn);
    }

    async function deleteJd(id, btn) {
        if (!confirm('Delete this job description? Its ATS results will also be removed.')) return;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
            const resp = await fetch(`/api/job-descriptions/${id}`, { method: 'DELETE' });
            if (!resp.ok) throw new Error('Delete failed');

            const row = document.getElementById('row-' + id);
            row.style.transition = 'opacity 0.3s';
            row.style.opacity = '0';
            setTimeout(() => row.remove(), 300);
        } catch {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-trash me-1"></i>Delete';
            const toast = document.getElementById('deleteToastEl');
            document.getElementById('deleteToastMsg').textContent = 'Failed to delete. Please try again.';
            toast.classList.remove('d-none');
            setTimeout(() => toast.classList.add('d-none'), 3000);
        }
    }
</script>
}
